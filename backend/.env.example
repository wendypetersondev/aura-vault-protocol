# Server
PORT=3001
NODE_ENV=development
AWS_REGION=us-east-1

# Secrets
# Production/staging must use AWS Secrets Manager. Do not place secret values in this file.
SECRETS_PROVIDER=env
APP_SECRETS_ID=
SECRETS_CACHE_TTL_MS=300000

# Local development only: put actual values in an untracked .env.local file.
JWT_SECRET=
UNSUBSCRIBE_SECRET=
SENDGRID_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_API_KEY=

# Redis — single node (default for local dev)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Redis — cluster mode (comma-separated host:port pairs, takes precedence over REDIS_URL)
# REDIS_CLUSTER=redis-node-1:6379,redis-node-2:6379,redis-node-3:6379

# Redis TLS (set to "true" for TLS-enabled clusters)
REDIS_TLS=false

# Cache TTLs (seconds)
CACHE_API_TTL=60
CACHE_DEFI_PRICE_TTL=30
CACHE_DEFI_POOL_TTL=60
