# ── Staging Environment Configuration ─────────────────────────────────────
# Copy to .env.staging and fill in values before running docker-compose.staging.yml

# Stellar / Soroban — Testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VAULT_CONTRACT_ID=<deployed-testnet-contract-id>

# Backend
JWT_SECRET=<generate-with: openssl rand -hex 32>
PORT=3001

# Data refresh (used by staging-test.sh cron)
DATA_REFRESH_CRON="0 3 * * *"
